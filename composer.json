{
    "name": "mostafax/dynamic-hybrid-reporting-engine",
    "description": "Dynamic Hybrid Reporting Engine — query MySQL & MongoDB via a unified JSON DSL, export to Excel/CSV/JSON, and power multi-tenant dashboards",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "reporting",
        "mysql",
        "mongodb",
        "dsl",
        "dashboard",
        "export",
        "saas",
        "multi-tenant",
        "analytics"
    ],
    "homepage": "https://packagist.org/packages/mostafax/dynamic-hybrid-reporting-engine",
    "authors": [
        {
            "name": "Mostafa",
            "email": "mostafa.m.elbiar2@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/cache": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/queue": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/validation": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "pestphp/pest": "^2.0|^3.0",
        "mockery/mockery": "^1.6"
    },
    "suggest": {
        "mongodb/laravel-mongodb": "Required for MongoDB data source support (^4.0|^5.0)",
        "phpoffice/phpspreadsheet": "Required for Excel (XLSX) export (^1.29|^2.0|^3.0)",
        "league/csv": "Required for optimised CSV streaming export (^9.0)"
    },
    "autoload": {
        "psr-4": {
            "Mostafax\\ReportingEngine\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mostafax\\ReportingEngine\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mostafax\\ReportingEngine\\ReportingEngineServiceProvider"
            ],
            "aliases": {
                "ReportingEngine": "Mostafax\\ReportingEngine\\Support\\Facades\\ReportingEngine"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
